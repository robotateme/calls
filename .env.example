APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_PORT=80

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=calls
DB_USERNAME=sail
DB_PASSWORD=password
FORWARD_DB_PORT=5432

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
FORWARD_REDIS_PORT=6379

KAFKA_BROKERS=kafka:9092
KAFKA_CONSUMER_ADAPTER=jsonl
KAFKA_PRODUCER_ADAPTER=console
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_PRODUCER_FLUSH_TIMEOUT_MS=10000
KAFKA_INCOMING_CALLS_TOPIC=incoming-calls
KAFKA_INCOMING_CALLS_GROUP=calls-incoming
KAFKA_TELEPHONY_FACTS_TOPIC=telephony.facts
KAFKA_TELEPHONY_FACTS_GROUP=calls-telephony-facts
KAFKA_TELEPHONY_COMMANDS_TOPIC=telephony.commands
KAFKA_CONSUMER_BATCH_LIMIT=1000
KAFKA_CONSUMER_TIMEOUT_MS=1000
OUTBOX_PUBLISH_INTERVAL_SECONDS=1
KAFKA_CONSOLE_PRODUCER_BINARY=kafka-console-producer.sh
KAFKA_CONSOLE_PRODUCER_TIMEOUT_SECONDS=10
TELEPHONY_OUTBOX_PUBLISH_LIMIT=100
TELEPHONY_OUTBOX_RETRY_DELAY_SECONDS=10
TELEPHONY_OUTBOX_MAX_ATTEMPTS=10
TELEPHONY_OUTBOX_PROCESSING_TIMEOUT_SECONDS=120
TELEPHONY_OUTBOX_REQUEUE_LIMIT=100
OPERATOR_RESERVATION_TTL_SECONDS=120
OPERATOR_RESERVATION_CLEANUP_LIMIT=100
OPERATOR_SEARCH_RETRY_MIN_DELAY_SECONDS=1
OPERATOR_SEARCH_RETRY_JITTER_SECONDS=5
OPERATOR_SEARCH_RETRY_MAX_DELAY_SECONDS=3600
DEAD_LETTER_RETENTION_DAYS=30
DEAD_LETTER_PRUNE_LIMIT=1000
FORWARD_KAFKA_PORT=9094
FORWARD_KAFKA_UI_PORT=8081

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
